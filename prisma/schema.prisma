generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum GameSource {
  STEAM
  EPIC
  MANUAL
  CONSOLE
  OTHER
}

enum GameStatus {
  UNPLAYED
  PLAYING
  FINISHED
  DROPPED
}

enum LinkedAccountProvider {
  STEAM
}

enum SyncStatus {
  SUCCESS
  FAILED
  PARTIAL
}

model LinkedAccount {
  id             String                @id @default(cuid())
  userId         String
  provider       LinkedAccountProvider
  providerUserId String
  profileUrl     String?
  lastSyncedAt   DateTime?
  createdAt      DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@index([userId])
}



enum FriendRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model FriendRequest {
  id           String              @id @default(cuid())
  requesterId  String
  recipientId  String
  status       FriendRequestStatus @default(PENDING)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  requester User @relation("FriendRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  recipient User @relation("FriendRequestRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([requesterId, recipientId])
  @@index([requesterId])
  @@index([recipientId])
}

model Game {
  id                 String     @id @default(cuid())
  rawgId             Int?       @unique
  steamAppId         Int?       @unique
  title              String
  slug               String?
  coverUrl           String?
  backgroundImageUrl String?
  screenshots        Json?
  tags               Json?
  description        String?
  releaseDate        DateTime?
  rawgRating         Float?
  genres             Json?
  platforms          Json?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  userGames          UserGame[]

  @@index([title])
}

model User {
  id               String          @id @default(cuid())
  authUserId       String?         @unique
  email            String          @unique
  username         String?         @unique
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  preferredGenres  Json?
  sessionLength    Int?

  linkedAccounts   LinkedAccount[]
  userGames        UserGame[]
  syncLogs         SyncLog[]

  sentFriendRequests     FriendRequest[] @relation("FriendRequestRequester")
  receivedFriendRequests FriendRequest[] @relation("FriendRequestRecipient")
}

model UserGame {
  id                String      @id @default(cuid())
  userId            String
  gameId            String
  source            GameSource
  playtimeMinutes   Int         @default(0)
  lastPlayedAt      DateTime?
  status            GameStatus  @default(UNPLAYED)
  personalRating    Int?
  notes             String?
  importedFromSteam Boolean     @default(false)
  isFavorite        Boolean     @default(false)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId, source])
  @@index([userId])
  @@index([gameId])
  @@index([status])
  @@index([lastPlayedAt])
}

model SyncLog {
  id        String      @id @default(cuid())
  userId    String
  provider  LinkedAccountProvider
  status    SyncStatus
  message   String?
  syncedAt  DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, syncedAt])
}